# 数据持久化目录（宿主机路径，支持绝对或相对路径）
# 不设则默认使用 docker-compose.yml 同级的 ./data 目录
# Windows 绝对路径示例：DATA_HOST_DIR=D:/storm-toolkit/data
# Linux 绝对路径示例：DATA_HOST_DIR=/var/lib/storm-toolkit/data
# DATA_HOST_DIR=./data

# 调度间隔（秒），默认 1 小时
SCHEDULE_INTERVAL_SECONDS=3600

# 活跃列表刷新间隔（秒），默认 1 小时
ACTIVE_LIST_REFRESH_SECONDS=3600

# Web 服务监听地址与端口
WEB_HOST=0.0.0.0
WEB_PORT=19995

# 是否启用 CMA（浙江水利厅）数据源（1/0），默认启用
# CMA 接口偶发不稳定时可临时关闭，仅用 zoom.earth 单源
CMA_ENABLED=1

# 每个 source 保留的最近预测批数（每 3h 一发，4 批≈12h）
FORECAST_BATCHES_KEEP=4

# HTTP 请求超时（秒）
HTTP_TIMEOUT=15
